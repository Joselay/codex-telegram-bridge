TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_ALLOWED_USER_ID=123456789

# Optional. Defaults to gpt-5.5 if omitted.
CODEX_MODEL=gpt-5.5

# Optional. Defaults to high if omitted.
CODEX_REASONING_LEVEL=high

# Optional. Defaults to ./.codex-telegram-store.json.
CODEX_TELEGRAM_STORE=.codex-telegram-store.json

# Optional. Comma-separated roots the bridge is allowed to upload files from.
# Defaults to your home directory. Use / only if you accept the wider data-leak risk.
TELEGRAM_FILE_SEND_ROOTS=~

# Optional. Max file size the bridge will upload to Telegram, in MB. Defaults to 50.
TELEGRAM_FILE_SEND_MAX_MB=50

# Optional voice-message support.
# Defaults match a local ~/whisper.cpp build on this machine.
WHISPER_CPP_BIN=~/whisper.cpp/build/bin/whisper-cli
WHISPER_CPP_MODEL=~/whisper.cpp/models/ggml-large-v3-turbo-q5_0.bin
# English-only voice input. The app rejects other values.
WHISPER_CPP_LANGUAGE=en

# Optional voice replies for Telegram voice inputs. Uses macOS say + ffmpeg.
TELEGRAM_REPLY_WITH_VOICE=true
TELEGRAM_VOICE_REPLY_MAX_CHARS=3500
# TELEGRAM_TTS_VOICE=Samantha
# FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
